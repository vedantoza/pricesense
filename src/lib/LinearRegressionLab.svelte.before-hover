<script lang="ts">
  type RegressionPoint = {
    id: number;
    x: number;
    y: number;
    predicted: number;
    residual: number;
    outlier: boolean;
  };

  const chartWidth = 760;
  const chartHeight = 390;
  const padding = {
    left: 68,
    right: 26,
    top: 28,
    bottom: 58
  };

  const ticks = [0, 1, 2, 3, 4, 5];

  let rawData = '';
  let xLabel = 'Price';
  let yLabel = 'Units sold';

  let points: RegressionPoint[] = [];
  let slope = 0;
  let intercept = 0;
  let rSquared = 0;
  let residualStandardDeviation = 0;
  let errorMessage = '';

  let xMin = 0;
  let xMax = 1;
  let yMin = 0;
  let yMax = 1;

  $: plotWidth = chartWidth - padding.left - padding.right;
  $: plotHeight = chartHeight - padding.top - padding.bottom;
  $: outlierCount = points.filter((point) => point.outlier).length;

  function scaleX(value: number): number {
    return (
      padding.left +
      ((value - xMin) / Math.max(xMax - xMin, Number.EPSILON)) *
        plotWidth
    );
  }

  function scaleY(value: number): number {
    return (
      padding.top +
      plotHeight -
      ((value - yMin) / Math.max(yMax - yMin, Number.EPSILON)) *
        plotHeight
    );
  }

  function tickValue(min: number, max: number, tick: number): number {
    return min + ((max - min) * tick) / 5;
  }

  function parseData(): Array<{ x: number; y: number }> {
    const rows: Array<{ x: number; y: number }> = [];

    for (const line of rawData.split(/\r?\n/)) {
      const trimmed = line.trim();

      if (!trimmed) continue;

      const pieces = trimmed.split(/[,\t; ]+/);

      if (pieces.length < 2) continue;

      const x = Number(pieces[0]);
      const y = Number(pieces[1]);

      // This also skips a header such as x,y.
      if (!Number.isFinite(x) || !Number.isFinite(y)) continue;

      rows.push({ x, y });
    }

    return rows;
  }

  function fitRegression(): void {
    errorMessage = '';

    const rows = parseData();

    if (rows.length < 3) {
      points = [];
      errorMessage =
        'Paste at least three valid observations containing one x value and one y value per row.';
      return;
    }

    const meanX =
      rows.reduce((total, row) => total + row.x, 0) / rows.length;

    const meanY =
      rows.reduce((total, row) => total + row.y, 0) / rows.length;

    const sumSquaredX = rows.reduce(
      (total, row) => total + (row.x - meanX) ** 2,
      0
    );

    if (sumSquaredX === 0) {
      points = [];
      errorMessage =
        'The independent-variable values cannot all be identical.';
      return;
    }

    const crossProduct = rows.reduce(
      (total, row) =>
        total + (row.x - meanX) * (row.y - meanY),
      0
    );

    slope = crossProduct / sumSquaredX;
    intercept = meanY - slope * meanX;

    const initialPoints = rows.map((row, index) => {
      const predicted = intercept + slope * row.x;

      return {
        id: index,
        x: row.x,
        y: row.y,
        predicted,
        residual: row.y - predicted,
        outlier: false
      };
    });

    const residualSumSquares = initialPoints.reduce(
      (total, point) => total + point.residual ** 2,
      0
    );

    residualStandardDeviation = Math.sqrt(
      residualSumSquares / Math.max(rows.length - 2, 1)
    );

    const outlierThreshold = 2 * residualStandardDeviation;

    points = initialPoints.map((point) => ({
      ...point,
      outlier:
        residualStandardDeviation > 0 &&
        Math.abs(point.residual) > outlierThreshold
    }));

    const totalSumSquares = rows.reduce(
      (total, row) => total + (row.y - meanY) ** 2,
      0
    );

    rSquared =
      totalSumSquares === 0
        ? 1
        : 1 - residualSumSquares / totalSumSquares;

    const rawXMin = Math.min(...rows.map((row) => row.x));
    const rawXMax = Math.max(...rows.map((row) => row.x));
    const rawYMin = Math.min(
      ...rows.map((row) => row.y),
      intercept + slope * rawXMin,
      intercept + slope * rawXMax
    );
    const rawYMax = Math.max(
      ...rows.map((row) => row.y),
      intercept + slope * rawXMin,
      intercept + slope * rawXMax
    );

    const xMargin = Math.max((rawXMax - rawXMin) * 0.08, 1);
    const yMargin = Math.max((rawYMax - rawYMin) * 0.08, 1);

    xMin = rawXMin - xMargin;
    xMax = rawXMax + xMargin;
    yMin = rawYMin - yMargin;
    yMax = rawYMax + yMargin;
  }

  function clearData(): void {
    rawData = '';
    points = [];
    slope = 0;
    intercept = 0;
    rSquared = 0;
    residualStandardDeviation = 0;
    errorMessage = '';
  }
</script>

<section class="regression-lab">
  <div class="lab-heading">
    <div>
      <span class="section-label">SIMPLE LINEAR REGRESSION</span>
      <h2>Regression line and outlier analysis</h2>
    </div>

    <div class="equations">
      <div>
        <small>Population model</small>
        <strong>y = β₀ + β₁x + ε</strong>
      </div>

      <div>
        <small>Estimated regression line</small>
        <strong>ŷ = b₀ + b₁x</strong>
      </div>
    </div>
  </div>

  <div class="definition-grid">
    <article>
      <strong>y</strong>
      <span>Dependent variable</span>
      <small>The outcome being predicted</small>
    </article>

    <article>
      <strong>x</strong>
      <span>Independent variable</span>
      <small>The predictor used by the model</small>
    </article>

    <article>
      <strong>β₀</strong>
      <span>Population intercept</span>
      <small>Estimated by b₀</small>
    </article>

    <article>
      <strong>β₁</strong>
      <span>Population slope</span>
      <small>Estimated by b₁</small>
    </article>

    <article>
      <strong>ε</strong>
      <span>Error term</span>
      <small>Unexplained variation in y</small>
    </article>
  </div>

  <p class="parameter-note">
    The population parameters β₀ and β₁ are generally unknown. They are
    estimated from the available sample data using b₀ and b₁.
  </p>

  <div class="data-workspace">
    <div class="data-entry">
      <div class="field-row">
        <label>
          <span>Independent-variable label</span>
          <input bind:value={xLabel} placeholder="Enter x-axis label" />
        </label>

        <label>
          <span>Dependent-variable label</span>
          <input bind:value={yLabel} placeholder="Enter y-axis label" />
        </label>
      </div>

      <label>
        <span>Paste two-column data</span>
        <textarea
          bind:value={rawData}
          rows="13"
          placeholder="Paste real observations here. Use one x,y pair per row."
        ></textarea>
      </label>

      <p class="format-note">
        Accepted separators: comma, tab, semicolon, or space. A header row is
        optional.
      </p>

      {#if errorMessage}
        <div class="error-message" role="alert">
          {errorMessage}
        </div>
      {/if}

      <div class="button-row">
        <button class="primary-button" type="button" onclick={fitRegression}>
          Generate scatter plot
        </button>

        <button class="secondary-button" type="button" onclick={clearData}>
          Clear
        </button>
      </div>
    </div>

    <div class="chart-area">
      {#if points.length > 0}
        <div class="metric-grid">
          <article>
            <span>Intercept b₀</span>
            <strong>{intercept.toFixed(3)}</strong>
          </article>

          <article>
            <span>Slope b₁</span>
            <strong>{slope.toFixed(3)}</strong>
          </article>

          <article>
            <span>R²</span>
            <strong>{rSquared.toFixed(3)}</strong>
          </article>

          <article>
            <span>Potential outliers</span>
            <strong>{outlierCount}</strong>
          </article>
        </div>

        <div class="chart-container">
          <svg
            viewBox={`0 0 ${chartWidth} ${chartHeight}`}
            role="img"
            aria-label="Scatter plot with regression line and potential outliers"
          >
            {#each ticks as tick}
              {@const horizontalValue = tickValue(yMin, yMax, tick)}
              {@const horizontalY = scaleY(horizontalValue)}

              <line
                x1={padding.left}
                y1={horizontalY}
                x2={chartWidth - padding.right}
                y2={horizontalY}
                class="grid-line"
              />

              <text
                x={padding.left - 10}
                y={horizontalY + 4}
                text-anchor="end"
                class="tick-label"
              >
                {horizontalValue.toFixed(1)}
              </text>
            {/each}

            {#each ticks as tick}
              {@const verticalValue = tickValue(xMin, xMax, tick)}
              {@const verticalX = scaleX(verticalValue)}

              <line
                x1={verticalX}
                y1={padding.top}
                x2={verticalX}
                y2={chartHeight - padding.bottom}
                class="grid-line"
              />

              <text
                x={verticalX}
                y={chartHeight - padding.bottom + 22}
                text-anchor="middle"
                class="tick-label"
              >
                {verticalValue.toFixed(1)}
              </text>
            {/each}

            <line
              x1={padding.left}
              y1={chartHeight - padding.bottom}
              x2={chartWidth - padding.right}
              y2={chartHeight - padding.bottom}
              class="axis-line"
            />

            <line
              x1={padding.left}
              y1={padding.top}
              x2={padding.left}
              y2={chartHeight - padding.bottom}
              class="axis-line"
            />

            <line
              x1={scaleX(xMin)}
              y1={scaleY(intercept + slope * xMin)}
              x2={scaleX(xMax)}
              y2={scaleY(intercept + slope * xMax)}
              class="regression-line"
            />

            {#each points as point}
              <circle
                cx={scaleX(point.x)}
                cy={scaleY(point.y)}
                r={point.outlier ? 7 : 5}
                class={point.outlier
                  ? 'scatter-point outlier-point'
                  : 'scatter-point'}
              >
                <title>
                  {xLabel}: {point.x}
                  {yLabel}: {point.y}
                  Residual: {point.residual.toFixed(3)}
                  {point.outlier ? 'Potential outlier' : 'Regular observation'}
                </title>
              </circle>
            {/each}

            <text
              x={padding.left + plotWidth / 2}
              y={chartHeight - 10}
              text-anchor="middle"
              class="axis-label"
            >
              {xLabel}
            </text>

            <text
              x="18"
              y={padding.top + plotHeight / 2}
              text-anchor="middle"
              transform={`rotate(-90 18 ${padding.top + plotHeight / 2})`}
              class="axis-label"
            >
              {yLabel}
            </text>
          </svg>
        </div>

        <div class="legend">
          <span>
            <i class="normal-dot"></i>
            Observation
          </span>

          <span>
            <i class="outlier-dot"></i>
            Potential outlier
          </span>

          <span>
            <i class="line-key"></i>
            Regression line
          </span>
        </div>

        <p class="outlier-note">
          Potential outliers are observations whose absolute regression
          residual is greater than two residual standard deviations. They
          should be reviewed rather than automatically deleted.
        </p>
      {:else}
        <div class="empty-chart">
          <div class="empty-icon">⌁</div>
          <h3>No observations loaded</h3>
          <p>
            Paste your real x and y values to generate the scatter plot,
            regression line, and potential-outlier indicators.
          </p>
        </div>
      {/if}
    </div>
  </div>
</section>

<style>
  .regression-lab {
    margin: 0 0 22px;
    padding: 24px;
    border: 1px solid #e7e7ef;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 35px rgba(37, 31, 61, 0.06);
  }


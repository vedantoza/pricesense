    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 20px;
  }

  .section-label {
    color: #e97800;
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.12em;
  }

  h2 {
    margin: 6px 0 0;
    color: #000080;
    font-size: 1.45rem;
    letter-spacing: -0.025em;
  }

  .equations {
    display: flex;
    gap: 10px;
  }

  .equations > div {
    min-width: 190px;
    padding: 12px 14px;
    border: 1px solid #ffd9b3;
    border-radius: 11px;
    background: #fff7ef;
  }

  .equations small,
  .equations strong {
    display: block;
  }

  .equations small {
    color: #7a6c61;
    font-size: 0.65rem;
  }

  .equations strong {
    margin-top: 5px;
    color: #000080;
    font-size: 0.92rem;
  }

  .definition-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 11px;
  }

  .definition-grid article {
    min-height: 105px;
    padding: 14px;
    border: 1px solid #ecebf2;
    border-radius: 12px;
    background: #fafafe;
  }

  .definition-grid strong,
  .definition-grid span,
  .definition-grid small {
    display: block;
  }

  .definition-grid strong {
    color: #ff8d21;
    font-size: 1.2rem;
  }

  .definition-grid span {
    margin-top: 8px;
    color: #262331;
    font-size: 0.74rem;
    font-weight: 750;
  }

  .definition-grid small {
    margin-top: 4px;
    color: #7d798b;
    font-size: 0.67rem;
  }

  .parameter-note {
    margin: 15px 0 22px;
    padding: 13px 15px;
    border-left: 4px solid #ff8d21;
    border-radius: 4px 10px 10px 4px;
    background: #fff8f0;
    color: #656172;
    font-size: 0.77rem;
    line-height: 1.55;
  }

  .data-workspace {
    display: grid;
    grid-template-columns: minmax(300px, 0.7fr) minmax(0, 1.3fr);
    gap: 20px;
  }

  .data-entry,
  .chart-area {
    border: 1px solid #ecebf2;
    border-radius: 15px;
    background: #fbfbfe;
    padding: 18px;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  label {
    display: block;
    margin-bottom: 15px;
  }

  label > span {
    display: block;
    margin-bottom: 7px;
    color: #545162;
    font-size: 0.72rem;
    font-weight: 750;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid #d9d8e3;
    border-radius: 10px;
    background: #ffffff;
    color: #242130;
    outline: none;
    padding: 11px 12px;
    font: inherit;
  }

  input:focus,
  textarea:focus {
    border-color: #ff8d21;
    box-shadow: 0 0 0 3px rgba(255, 141, 33, 0.13);
  }

  textarea {
    resize: vertical;
    min-height: 230px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      monospace;
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .format-note {
    margin: -7px 0 15px;
    color: #85818f;
    font-size: 0.67rem;
  }

  .error-message {
    margin-bottom: 14px;
    padding: 11px 13px;
    border: 1px solid #f2c3bd;
    border-radius: 9px;
    background: #fff1ef;
    color: #9c3027;
    font-size: 0.75rem;
  }

  .button-row {
    display: flex;
    gap: 9px;
  }

  button {
    min-height: 42px;
    border-radius: 9px;
    padding: 0 14px;
    font: inherit;
    font-size: 0.75rem;
    font-weight: 800;
    cursor: pointer;
  }

  .primary-button {
    border: 0;
    background: #000080;
    color: #ffffff;
  }

  .primary-button:hover {
    background: #1717a7;
  }

  .secondary-button {
    border: 1px solid #d7d5df;
    background: #ffffff;
    color: #4f4b5b;
  }

  .secondary-button:hover {
    border-color: #ff8d21;
    color: #c65f00;
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 9px;
    margin-bottom: 13px;
  }

  .metric-grid article {
    padding: 11px;
    border: 1px solid #e8e7ef;
    border-radius: 10px;
    background: #ffffff;
  }

  .metric-grid span,
  .metric-grid strong {
    display: block;
  }

  .metric-grid span {
    color: #767281;
    font-size: 0.64rem;
  }

  .metric-grid strong {
    margin-top: 5px;
    color: #000080;
    font-size: 1rem;
  }

  .chart-container {
    width: 100%;
    overflow-x: auto;
    border-radius: 12px;
    background: #ffffff;
  }

  svg {
    display: block;
    width: 100%;
    min-width: 600px;
    height: auto;
  }

  .grid-line {
    stroke: #ecebf2;
    stroke-width: 1;
  }

  .axis-line {
    stroke: #aaa7b4;
    stroke-width: 1.3;
  }

  .regression-line {
    stroke: #000080;
    stroke-width: 3;
  }

  .scatter-point {
    fill: #000080;
    stroke: #ffffff;
    stroke-width: 2;
  }

  .outlier-point {
    fill: #ff8d21;
    stroke: #8b4000;
    stroke-width: 2.5;
  }

  .tick-label {
    fill: #7d7988;
    font-size: 10px;
  }

  .axis-label {
    fill: #454151;
    font-size: 11px;
    font-weight: 700;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 12px;
    color: #686473;
    font-size: 0.68rem;
  }

  .legend span {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .normal-dot,
  .outlier-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .normal-dot {
    background: #000080;
  }

  .outlier-dot {
    background: #ff8d21;
    border: 1px solid #8b4000;
  }

  .line-key {
    width: 18px;
    height: 3px;
    border-radius: 3px;
    background: #000080;
  }

  .outlier-note {
    margin: 13px 0 0;
    color: #777382;
    font-size: 0.68rem;
    line-height: 1.5;
  }

  .empty-chart {
    min-height: 475px;
    display: grid;
    place-items: center;
    align-content: center;
    text-align: center;
    color: #767281;
  }

  .empty-icon {
    color: #ff8d21;
    font-size: 3rem;
  }

  .empty-chart h3 {
    margin: 10px 0 5px;
    color: #000080;
  }

  .empty-chart p {
    max-width: 430px;
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.55;
  }

  @media (max-width: 1050px) {
    .lab-heading,
    .data-workspace {
      grid-template-columns: 1fr;
    }

    .lab-heading {
      flex-direction: column;
    }

    .definition-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 700px) {
    .regression-lab {
      padding: 17px;
    }

    .equations {
      width: 100%;
      flex-direction: column;
    }

    .equations > div {
      min-width: 0;
    }

    .definition-grid,
    .field-row,
    .metric-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 470px) {
    .definition-grid,
    .field-row,
    .metric-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
